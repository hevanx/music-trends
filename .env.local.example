# Anthropic — get at console.anthropic.com
ANTHROPIC_API_KEY=

# Tavily — get at tavily.com (free tier works)
TAVILY_API_KEY=

# Vercel KV — auto-populated when you link a KV store in your Vercel project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Random string — used to authorize the cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=
